<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>dev.anima.server</string>

    <key>ProgramArguments</key>
    <array>
        <string>__ANIMA_BIN__</string>
        <string>__ANIMA_CONFIG__</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__ANIMA_DIR__</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>StandardOutPath</key>
    <string>__ANIMA_DIR__/logs/anima-server.log</string>

    <key>StandardErrorPath</key>
    <string>__ANIMA_DIR__/logs/anima-server.err</string>

    <key>ThrottleInterval</key>
    <integer>5</integer>
</dict>
</plist>
